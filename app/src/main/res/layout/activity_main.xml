<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity"
    android:background="@color/white">
    <!-- контейнер для отображения символа валюты -->
    <LinearLayout
        android:id="@+id/Linear"
        android:layout_width="400dp"
        android:layout_height="400dp"
        android:layout_marginTop="50dp"
        android:background="@drawable/background_layout"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <!-- Текстовое поле для отображения символа валюты -->
        <TextView
            android:id="@+id/valyuta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="$"
            android:textColor="@color/white"
            android:textSize="180sp"
            android:textAlignment="center"/>
    </LinearLayout>
    <!-- Подпись для поля ввода курса валюты -->
    <TextView
        android:id="@+id/tv1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Курс валюты:"
        android:textColor="#ABABAB"
        android:textSize="18sp"
        app:layout_constraintTop_toBottomOf="@+id/Linear"
        android:layout_marginTop="30dp"
        android:layout_marginLeft="20dp"/>
    <!-- Поле ввода курса -->
    <EditText
        android:id="@+id/cours"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@+id/tv1"
        android:layout_marginTop="0dp"
        android:layout_marginLeft="20dp"
        android:layout_marginRight="20dp"/>
    <!-- Подпись для поля ввода суммы -->
    <TextView
        android:id="@+id/tv2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Сумма:"
        android:textColor="#ABABAB"
        android:textSize="18sp"
        app:layout_constraintTop_toBottomOf="@+id/cours"
        android:layout_marginTop="30dp"
        android:layout_marginLeft="20dp"/>
    <!-- Поле ввода суммы -->
    <EditText
        android:id="@+id/count"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@+id/tv2"
        android:layout_marginTop="0dp"
        android:layout_marginLeft="20dp"
        android:layout_marginRight="20dp"/>
    <!-- Переключатель для выбора конвертации -->
    <Switch
        android:id="@+id/Switch"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Перевести в $"
        app:layout_constraintTop_toBottomOf="@+id/count"
        android:layout_marginRight="20dp"
        android:layout_marginLeft="250dp"/>
    <!-- Главное текстовое поле для отображения результата конвертации -->
    <TextView
        android:id="@+id/MainTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@+id/Switch"
        android:text="0 р."
        android:textAlignment="center"
        android:textSize="45sp"
        android:layout_marginTop="30dp"/>
    <!-- Кнопка для выполнения конвертации -->
    <Button
        android:id="@+id/button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:background="@drawable/background_button"
        android:onClick="Consider"
        android:text="ПЕРЕВЕСТИ"
        android:textColor="@android:color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        android:paddingVertical="12dp"
        app:layout_constraintTop_toBottomOf="@+id/MainTextView"/>
    <!-- Кнопка для открытия сайта с курсом валют -->
    <TextView
        android:id="@+id/CheckCourse"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="15dp"
        android:onClick="URL"
        android:text="Не знаете курс доллара?"
        android:textAlignment="center"
        android:textColor="#3EBA4F"
        android:textSize="16sp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintTop_toBottomOf="@+id/button" />
</androidx.constraintlayout.widget.ConstraintLayout>